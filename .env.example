# Public site URL (used for sitemap, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://www.bespoketech.com.ng

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# Bespoke AI - required for Gemini streaming
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Email (Resend, server-only) ─────────────────────────────────────────────
# Outbound transactional + admin-composed email. Verify the domain in Resend
# first (adds DKIM + SPF DNS records). Without this key, sends are skipped and
# the contact form still records enquiries to the database.
RESEND_API_KEY=
# Optional address overrides — defaults are derived from bespoketech.com.ng.
# no-reply sends automated mail; support@ is the monitored Reply-To (Cloudflare
# Email Routing forwards founder@/manager@/support@ to the team Gmail).
EMAIL_FROM_NOREPLY=no-reply@bespoketech.com.ng
EMAIL_SUPPORT=support@bespoketech.com.ng
# Where new website enquiries are delivered internally (defaults to support@).
EMAIL_CONTACT_NOTIFY=support@bespoketech.com.ng
# Personal sender identities for the admin outreach tool — independent of
# ADMIN_FOUNDER_EMAIL/ADMIN_MANAGER_EMAIL (those are admin *login* identities
# and may be a personal inbox Resend cannot send from). Defaults below.
# EMAIL_FOUNDER=founder@bespoketech.com.ng
# EMAIL_MANAGER=manager@bespoketech.com.ng

# ── Cloudflare Turnstile (contact-form bot protection) ──────────────────────
# Site key is exposed to the browser; secret stays server-only. If both are
# unset, the form falls back to honeypot + rate limiting only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAD63WAjjzT9yTtt4
TURNSTILE_SECRET=

# Bespoke AI persistence - optional locally, required to persist conversations
DATABASE_URL=

# Cloudflare R2 - optional server-only storage adapter
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Bespoke Admin System. A DATABASE_URL is required in every environment; the
# admin runtime fails closed when it is absent.
ADMIN_ENABLED=true
ADMIN_BASE_URL=http://localhost:3000/admin
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes
ADMIN_CODE_PEPPER=replace-with-a-separate-high-entropy-secret
ADMIN_FOUNDER_EMAIL=founder@bespoketech.com.ng
ADMIN_FOUNDER_NAME=Founder Admin
ADMIN_FOUNDER_TOTP_SECRET=
ADMIN_FOUNDER_RECOVERY_HASHES=
ADMIN_FOUNDER_BOOTSTRAP_CODE=
ADMIN_MANAGER_EMAIL=manager@bespoketech.com.ng
ADMIN_MANAGER_NAME=Admin Manager
ADMIN_MANAGER_TOTP_SECRET=
ADMIN_MANAGER_RECOVERY_HASHES=
ADMIN_MANAGER_BOOTSTRAP_CODE=
ADMIN_ALLOW_BOOTSTRAP=false
# Secret code required (with a pre-authorized admin email) to enroll an
# authenticator at /admin/register. Share privately; rotate if exposed.
ADMIN_REGISTRATION_CODE=
ADMIN_CRON_SECRET=replace-with-a-long-random-secret
